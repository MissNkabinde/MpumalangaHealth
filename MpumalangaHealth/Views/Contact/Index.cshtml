@{
    ViewData["Title"] = "Contact Us";
}

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <h1 class="display-5 fw-bold text-primary mb-3">Contact Us</h1>
                <p class="lead text-muted">Get in touch with the Mpumalanga Department of Health</p>
            </div>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="container py-5">
    <div class="row">
        <!-- Contact Information -->
        <div class="col-lg-6 mb-5">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-info-circle me-2"></i>Contact Information</h4>
                </div>
                <div class="card-body">
                    <!-- Head Office -->
                    <div class="mb-4">
                        <h5 class="text-primary mb-3">
                            <i class="fas fa-building me-2"></i>Head Office
                        </h5>
                        <p class="mb-2">
                            <i class="fas fa-map-marker-alt text-primary me-2"></i>
                            <strong>Provincial Offices</strong><br>
                            Indwe Building, Government Boulevard<br>
                            Riverside Park, Mbombela, 1200
                        </p>
                        <p class="mb-1">
                            <i class="fas fa-phone text-primary me-2"></i>
                            <strong>Tel:</strong> 013 766 3000
                        </p>
                        <p class="mb-0">
                            <i class="fas fa-fax text-primary me-2"></i>
                            <strong>Fax:</strong> 013 766 3001
                        </p>
                    </div>

                    <!-- District Offices -->
                    <div class="mb-4">
                        <h5 class="text-primary mb-3">
                            <i class="fas fa-map me-2"></i>District Offices
                        </h5>

                        <div class="mb-3">
                            <h6 class="text-dark">Ehlanzeni District</h6>
                            <p class="mb-1 small">Tel: 013 762 2013</p>
                            <p class="mb-0 small">Email: ehlanzeni@mpuhealth.gov.za</p>
                        </div>

                        <div class="mb-3">
                            <h6 class="text-dark">Gert Sibande District</h6>
                            <p class="mb-1 small">Tel: 017 811 2700</p>
                            <p class="mb-0 small">Email: gertsibande@mpuhealth.gov.za</p>
                        </div>

                        <div class="mb-0">
                            <h6 class="text-dark">Nkangala District</h6>
                            <p class="mb-1 small">Tel: 013 690 6300</p>
                            <p class="mb-0 small">Email: nkangala@mpuhealth.gov.za</p>
                        </div>
                    </div>

                    <!-- Emergency Contacts -->
                    <div>
                        <h5 class="text-danger mb-3">
                            <i class="fas fa-ambulance me-2"></i>Emergency Contacts
                        </h5>
                        <div class="alert alert-danger">
                            <p class="mb-1"><strong>Ambulance:</strong> 10177</p>
                            <p class="mb-1"><strong>Cellphone Emergency:</strong> 112</p>
                            <p class="mb-0"><strong>Police:</strong> 10111</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Contact Form -->
        <div class="col-lg-6 mb-5">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-envelope me-2"></i>Quick Contact</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Note:</strong> For immediate assistance, please call our contact numbers above.
                    </div>

                    <div class="contact-methods">
                        <div class="mb-4">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-phone-volume me-2"></i>Telephone
                            </h6>
                            <p class="mb-2">
                                <strong>Switchboard:</strong> 013 766 3000<br>
                                <small class="text-muted">Monday - Thursday: 07:30 - 16:30, Friday: 07:30 - 13:00</small>
                            </p>
                        </div>

                        <div class="mb-4">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-envelope me-2"></i>Email
                            </h6>
                            <p class="mb-2">
                                <strong>General Inquiries:</strong> info@mpuhealth.gov.za
                            </p>
                            <p class="mb-0">
                                <strong>Media Relations:</strong> media@mpuhealth.gov.za
                            </p>
                        </div>

                        <div class="mb-0">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-comments me-2"></i>Online
                            </h6>
                            <div class="d-flex gap-2 flex-wrap">
                                <a href="#" class="btn btn-outline-primary btn-sm">
                                    <i class="fab fa-facebook-f me-1"></i>Facebook
                                </a>
                                <a href="#" class="btn btn-outline-info btn-sm">
                                    <i class="fab fa-twitter me-1"></i>Twitter
                                </a>
                                <a href="#" class="btn btn-outline-success btn-sm">
                                    <i class="fab fa-whatsapp me-1"></i>WhatsApp
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Additional Information -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4 class="text-primary mb-4">
                        <i class="fas fa-clock me-2"></i>Office Hours & Additional Information
                    </h4>

                    <div class="row">
                        <div class="col-md-6">
                            <h5 class="text-dark mb-3">Operating Hours</h5>
                            <ul class="list-unstyled">
                                <li class="mb-2">
                                    <i class="fas fa-check text-success me-2"></i>
                                    <strong>Monday - Thursday:</strong> 07:30 - 16:30
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-check text-success me-2"></i>
                                    <strong>Friday:</strong> 07:30 - 13:00
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-times text-danger me-2"></i>
                                    <strong>Weekends & Public Holidays:</strong> Closed
                                </li>
                                <li>
                                    <i class="fas fa-ambulance text-warning me-2"></i>
                                    <strong>After Hours:</strong> Emergency services only
                                </li>
                            </ul>
                        </div>

                        <div class="col-md-6">
                            <h5 class="text-dark mb-3">Departments & Services</h5>
                            <ul class="list-unstyled">
                                <li class="mb-2">
                                    <i class="fas fa-user-md text-primary me-2"></i>
                                    <strong>Patient Services:</strong> 013 766 3100
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-briefcase text-primary me-2"></i>
                                    <strong>HR & Careers:</strong> 013 766 3200
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-file-contract text-primary me-2"></i>
                                    <strong>Tenders:</strong> 013 766 3300
                                </li>
                                <li>
                                    <i class="fas fa-comment-medical text-primary me-2"></i>
                                    <strong>Complaints Hotline:</strong> 0800 123 456
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Map & Location Section -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-map-marked-alt me-2"></i>Our Location</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h5 class="text-primary mb-3">Head Office Directions</h5>
                            <p class="mb-3">
                                Our provincial offices are located in the Indwe Building at Riverside Park,
                                easily accessible from the N4 highway.
                            </p>
                            <div class="mb-3">
                                <h6 class="text-dark">Parking Information</h6>
                                <p class="small text-muted mb-0">
                                    Ample visitor parking available. Security-controlled access.
                                </p>
                            </div>
                            <div class="mb-0">
                                <h6 class="text-dark">Public Transport</h6>
                                <p class="small text-muted mb-0">
                                    Accessible via municipal bus routes and taxi services.
                                </p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <!-- Simple Map Placeholder -->
                            <div class="bg-light rounded p-4 text-center h-100">
                                <i class="fas fa-map fa-3x text-muted mb-3"></i>
                                <h6 class="text-muted">Mpumalanga Health Head Office</h6>
                                <p class="small text-muted mb-3">
                                    Indwe Building, Government Boulevard<br>
                                    Riverside Park, Mbombela, 1200
                                </p>
                                <a href="https://maps.google.com/?q=Indwe+Building+Government+Boulevard+Mbombela+1200"
                                   target="_blank" class="btn btn-primary btn-sm">
                                    <i class="fas fa-directions me-1"></i>Get Directions
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>