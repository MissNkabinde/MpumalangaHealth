@model IEnumerable<Tender>
@{
    ViewData["Title"] = ViewBag.Title ?? "Tenders & Bidding Opportunities";
}

<div class="tenders-hero">
    <div class="container text-center">
        <div class="tenders-hero-label">
            <i class="fas fa-gavel me-2"></i>PROCUREMENT PORTAL
        </div>
        <h1 class="tenders-hero-title">
            Tenders & <span>Opportunities</span>
        </h1>
        <p class="tenders-hero-text">
            Partner with Mpumalanga Department of Health to deliver quality healthcare services
        </p>

        <!-- Search -->
        <form asp-action="Search" method="get" class="tenders-search">
            <input type="text" name="query" class="tenders-search-input"
                   placeholder="Search by tender number, title, department..."
                   value="@ViewBag.SearchQuery">
            <button type="submit" class="tenders-search-btn">
                <i class="fas fa-search me-2"></i>Search
            </button>
        </form>
    </div>
</div>

<div class="container py-4">
    <!-- Statistics -->
    <div class="tenders-stats-grid">
        <div class="tenders-stat-card">
            <div>
                <div class="tenders-stat-number">@ViewBag.OpenTenders</div>
                <div class="tenders-stat-label">Open Tenders</div>
            </div>
            <div class="tenders-stat-icon">
                <i class="fas fa-folder-open"></i>
            </div>
        </div>
        <div class="tenders-stat-card">
            <div>
                <div class="tenders-stat-number">@ViewBag.ClosingSoon</div>
                <div class="tenders-stat-label">Closing Soon</div>
            </div>
            <div class="tenders-stat-icon">
                <i class="fas fa-hourglass-half"></i>
            </div>
        </div>
        <div class="tenders-stat-card">
            <div>
                <div class="tenders-stat-number">@ViewBag.ClosedTenders</div>
                <div class="tenders-stat-label">Closed</div>
            </div>
            <div class="tenders-stat-icon">
                <i class="fas fa-check-circle"></i>
            </div>
        </div>
        <div class="tenders-stat-card">
            <div>
                <div class="tenders-stat-number">@ViewBag.TotalTenders</div>
                <div class="tenders-stat-label">Total Tenders</div>
            </div>
            <div class="tenders-stat-icon">
                <i class="fas fa-file-contract"></i>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="tenders-filter-bar">
        <span class="tenders-filter-label">
            <i class="fas fa-filter"></i>Filter:
        </span>

        <a href="@Url.Action("Index")"
           class="tenders-filter-link @(string.IsNullOrEmpty(ViewBag.CurrentStatus) && string.IsNullOrEmpty(ViewBag.CurrentCategory) ? "active" : "")">
            All Tenders
        </a>

        <a href="@Url.Action("Open")"
           class="tenders-filter-link @(ViewBag.CurrentStatus == "Open" ? "active" : "")">
            <i class="fas fa-folder-open"></i>Open
        </a>

        <a href="@Url.Action("ClosingSoon")"
           class="tenders-filter-link @(ViewBag.CurrentStatus == "ClosingSoon" ? "active" : "")">
            <i class="fas fa-hourglass-half"></i>Closing Soon
        </a>

        <span class="mx-2 text-secondary">|</span>

        <span class="tenders-filter-label">
            <i class="fas fa-tag"></i>Category:
        </span>

        <select class="tenders-category-dropdown" onchange="window.location.href=this.value;">
            <option value="">Select Category</option>
            <option value="@Url.Action("Category", new { category = "Medical Equipment" })">Medical Equipment</option>
            <option value="@Url.Action("Category", new { category = "Construction" })">Construction</option>
            <option value="@Url.Action("Category", new { category = "Services" })">Services</option>
            <option value="@Url.Action("Category", new { category = "Information Technology" })">ICT</option>
            <option value="@Url.Action("Category", new { category = "Fleet Management" })">Fleet Management</option>
        </select>
    </div>

    <!-- Featured Tenders -->
    @if (ViewBag.FeaturedTenders != null && ((IEnumerable<Tender>)ViewBag.FeaturedTenders).Any())
    {
        <div class="mb-5">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h5 class="fw-bold mb-0" style="color: var(--dark-gray);">
                    <span class="featured-badge me-3">
                        <i class="fas fa-star"></i>Featured
                    </span>
                    Top Opportunities
                </h5>
                <span class="text-secondary">@(((IEnumerable<Tender>)ViewBag.FeaturedTenders).Count()) featured</span>
            </div>
            <div class="row g-4">
                @foreach (var tender in ViewBag.FeaturedTenders)
                {
                    <div class="col-md-4">
                        <div class="tender-card featured">
                            <div class="tender-card-header">
                                <span class="tender-number">
                                    <i class="fas fa-hashtag"></i>@tender.TenderNumber
                                </span>
                                <span class="tender-status tender-status-open">
                                    <i class="fas fa-check-circle"></i>@tender.Status
                                </span>
                            </div>

                            <h5 class="tender-title">
                                <a href="@Url.Action("Details", new { id = tender.Id })">@tender.Title</a>
                            </h5>

                            <div class="tender-meta">
                                <span class="tender-meta-item">
                                    <i class="fas fa-building"></i>@tender.Department
                                </span>
                                <span class="tender-meta-item">
                                    <i class="fas fa-tag"></i>@tender.Category
                                </span>
                            </div>

                            <p class="tender-description">
                                @(tender.Description.Length > 100 ? tender.Description.Substring(0, 100) + "..." : tender.Description)
                            </p>

                            <div class="tender-footer">
                                <div class="tender-budget">
                                    <small>Budget</small>
                                    <span>R @(tender.Budget?.ToString("N0") ?? "TBC")</span>
                                </div>
                                <div class="tender-deadline">
                                    <small>Closing</small>
                                    <strong>@tender.ClosingDate.ToString("dd MMM yyyy")</strong>
                                </div>
                            </div>

                            <a href="@Url.Action("Details", new { id = tender.Id })"
                               class="tender-btn tender-btn-outline tender-btn-block mt-3">
                                View Details <i class="fas fa-arrow-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- All Tenders -->
    <div>
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h4 class="fw-bold mb-0" style="color: var(--dark-gray);">
                <i class="fas fa-file-contract" style="color: var(--primary-green); margin-right: 0.75rem;"></i>
                @(ViewBag.Title ?? "Current Tenders")
            </h4>
            <span class="text-secondary">@Model.Count() opportunities available</span>
        </div>

        @if (Model.Any())
        {
            <div class="row g-4">
                @foreach (var tender in Model)
                {
                    <div class="col-lg-6">
                        <div class="tender-card">
                            <div class="tender-card-header">
                                <span class="tender-number">
                                    <i class="fas fa-hashtag"></i>@tender.TenderNumber
                                </span>
                                <span class="tender-status
                                            @(tender.Status == "Open" ? "tender-status-open" :
                                                                            tender.Status == "Closing Soon" ? "tender-status-closing" :
                                                                            "tender-status-closed")">
                            @if (tender.Status == "Closing Soon")
                                    {
                                        <i class="fas fa-clock"></i>
                                    }
                                    else if (tender.Status == "Open")
                                    {
                                        <i class="fas fa-check-circle"></i>
                                    }
                                    @tender.Status
                                </span>
                            </div>

                            <h5 class="tender-title">
                                <a href="@Url.Action("Details", new { id = tender.Id })">@tender.Title</a>
                            </h5>

                            <div class="tender-meta">
                                <span class="tender-meta-item">
                                    <i class="fas fa-building"></i>@tender.Department
                                </span>
                                <span class="tender-meta-item">
                                    <i class="fas fa-tag"></i>@tender.Category
                                </span>
                            </div>

                            <p class="tender-description">
                                @(tender.Description.Length > 150 ? tender.Description.Substring(0, 150) + "..." : tender.Description)
                            </p>

                            <div class="tender-footer">
                                <div class="tender-budget">
                                    <small>Budget</small>
                                    <span>@(tender.Budget.HasValue ? $"R {tender.Budget.Value:N0}" : "Not specified")</span>
                                </div>
                                <div class="tender-deadline @(tender.IsOpen && tender.DaysRemaining <= 7 ? "urgent" : "")">
                                    <small>Closing</small>
                                    <strong>
                                        @tender.ClosingDate.ToString("dd MMM yyyy")
                                        @if (tender.IsOpen && tender.DaysRemaining <= 7)
                                        {
                                            <span class="days-left">@tender.DaysRemaining days</span>
                                        }
                                    </strong>
                                </div>
                            </div>

                            <div class="mt-3">
                                <a href="@Url.Action("Details", new { id = tender.Id })"
                                   class="tender-btn tender-btn-primary w-100">
                                    <i class="fas fa-eye me-2"></i>View Tender Details
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="tenders-empty">
                <div class="tenders-empty-icon">
                    <i class="fas fa-file-contract"></i>
                </div>
                <h5 class="tenders-empty-title">No tenders found</h5>
                @if (!string.IsNullOrEmpty(ViewBag.SearchQuery))
                {
                    <p class="tenders-empty-text">
                        No results found for "@ViewBag.SearchQuery"
                    </p>
                    <a href="@Url.Action("Index")" class="tender-btn tender-btn-primary">
                        <i class="fas fa-times me-2"></i>Clear Search
                    </a>
                }
                else
                {
                    <p class="tenders-empty-text">
                        There are currently no tenders available. Please check back later.
                    </p>
                }
            </div>
        }
    </div>
</div>