@model List<HealthService>
@{
    ViewData["Title"] = ViewBag.Category + " Services";
}

<div class="container py-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Services")">Our Services</a></li>
            <li class="breadcrumb-item active" aria-current="page">@ViewBag.Category</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="row mb-5">
        <div class="col-12">
            <h1 class="display-5 fw-bold text-primary mb-3">@ViewBag.Category Services</h1>
            <p class="lead text-muted">Explore our comprehensive @ViewBag.Category.ToLower() services</p>
        </div>
    </div>

    <!-- Services Grid -->
    <div class="row">
        @foreach (var service in Model)
        {
            <div class="col-lg-6 mb-4">
                <div class="card service-card h-100 shadow-sm @(service.IsFeatured ? "border-warning" : "")">
                    @if (service.IsFeatured)
                    {
                        <div class="card-header bg-warning text-dark py-2">
                            <small><i class="fas fa-star me-1"></i>KEY SERVICE</small>
                        </div>
                    }
                    <div class="card-body">
                        <!-- Service Header -->
                        <div class="d-flex align-items-start mb-3">
                            <div class="service-icon me-3">
                                <i class="@service.Icon fa-2x text-primary"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="card-title text-primary mb-1">@service.Name</h5>
                                <p class="card-text text-muted small mb-0">@service.Description</p>
                            </div>
                        </div>

                        <!-- Services Included -->
                        <div class="mb-3">
                            <h6 class="text-primary mb-2">Services Include:</h6>
                            <ul class="list-unstyled mb-0">
                                @foreach (var item in service.ServicesIncluded.Take(3))
                                {
                                    <li class="small text-muted mb-1">
                                        <i class="fas fa-check-circle text-primary me-2"></i>@item
                                    </li>
                                }
                                @if (service.ServicesIncluded.Count > 3)
                                {
                                    <li class="small text-muted">
                                        <i class="fas fa-plus-circle text-primary me-2"></i>
                                        And @(service.ServicesIncluded.Count - 3) more services
                                    </li>
                                }
                            </ul>
                        </div>

                        <!-- Target Audience -->
                        <div class="mb-3">
                            <small class="text-muted">
                                <i class="fas fa-users me-1"></i>
                                <strong>For:</strong> @service.TargetAudience
                            </small>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex justify-content-between align-items-center">
                            <a href="@Url.Action("Details", new { id = service.Id })" class="btn btn-primary btn-sm">
                                <i class="fas fa-info-circle me-1"></i>Details
                            </a>
                            <small class="text-muted">
                                <i class="fas fa-phone me-1"></i>@service.ContactDepartment
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- No Services Message -->
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-clipboard-list fa-3x text-muted mb-3"></i>
            <h4 class="text-muted">No services found in this category</h4>
            <p class="text-muted">Please check back later or explore other service categories</p>
            <a href="@Url.Action("Index")" class="btn btn-primary mt-3">
                <i class="fas fa-arrow-left me-2"></i>Back to All Services
            </a>
        </div>
    }

    <!-- Category Information -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="card bg-light">
                <div class="card-body">
                    <h4 class="text-primary mb-3">
                        <i class="fas fa-info-circle me-2"></i>About @ViewBag.Category Services
                    </h4>
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Access Information:</h6>
                            <ul class="small text-muted">
                                <li>Most services available at clinics and hospitals</li>
                                <li>Some services require appointment or referral</li>
                                <li>Emergency services available 24/7</li>
                                <li>Bring your ID and clinic card when visiting</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h6>General Requirements:</h6>
                            <ul class="small text-muted">
                                <li>South African ID or valid documentation</li>
                                <li>Clinic card for returning patients</li>
                                <li>Medical referral if required</li>
                                <li>Previous medical records if available</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .service-card {
        transition: all 0.3s ease;
        border: none;
    }

        .service-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1) !important;
        }

        .service-card.border-warning {
            border: 2px solid var(--mustard) !important;
        }

    .service-icon {
        width: 50px;
        height: 50px;
        background-color: rgba(1, 71, 171, 0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>