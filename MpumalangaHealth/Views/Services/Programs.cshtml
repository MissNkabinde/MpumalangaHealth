@model List<HealthProgram>
@{
    ViewData["Title"] = "Health Programs";
}

<div class="container py-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Services")">Our Services</a></li>
            <li class="breadcrumb-item active" aria-current="page">Health Programs</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-5 fw-bold text-primary mb-3">Health Programs</h1>
            <p class="lead text-muted">Specialized health initiatives and disease prevention programs</p>
        </div>
    </div>

    <!-- Programs Grid -->
    <div class="row">
        @foreach (var program in Model)
        {
            <div class="col-lg-6 mb-4">
                <div class="card program-card h-100 shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="card-title mb-0">@program.Name</h5>
                    </div>
                    <div class="card-body">
                        <!-- Program Description -->
                        <p class="text-muted mb-3">@program.Description</p>

                        <!-- Program Objectives -->
                        <div class="mb-3">
                            <h6 class="text-primary">Objectives:</h6>
                            <div class="bg-light p-3 rounded small">
                                @Html.Raw(program.Objectives.Replace("\n", "<br>"))
                            </div>
                        </div>

                        <!-- Target Group -->
                        <div class="mb-3">
                            <h6 class="text-primary">Target Group:</h6>
                            <p class="text-muted small mb-0">@program.TargetGroup</p>
                        </div>

                        <!-- Services Provided -->
                        <div class="mb-3">
                            <h6 class="text-primary">Services Provided:</h6>
                            <div class="bg-light p-3 rounded small">
                                @Html.Raw(program.ServicesProvided.Replace("\n", "<br>"))
                            </div>
                        </div>

                        <!-- Program Information -->
                        <div class="program-meta">
                            <div class="row text-center">
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="fas fa-clock me-1"></i><br>
                                        @program.ProgramDuration
                                    </small>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="fas fa-phone me-1"></i><br>
                                        @program.ContactInfo
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Additional Information -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="card bg-light">
                <div class="card-body">
                    <h4 class="text-primary mb-3">
                        <i class="fas fa-question-circle me-2"></i>About Our Health Programs
                    </h4>
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Program Benefits:</h6>
                            <ul class="small text-muted">
                                <li>Evidence-based interventions</li>
                                <li>Community-centered approach</li>
                                <li>Multi-sectoral collaboration</li>
                                <li>Regular monitoring and evaluation</li>
                                <li>Continuous quality improvement</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h6>Getting Involved:</h6>
                            <ul class="small text-muted">
                                <li>Visit your nearest health facility</li>
                                <li>Speak to healthcare providers</li>
                                <li>Attend community health talks</li>
                                <li>Participate in screening events</li>
                                <li>Join support groups</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .program-card {
        transition: all 0.3s ease;
        border: none;
    }

        .program-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
        }

    .program-meta {
        border-top: 1px solid #e9ecef;
        padding-top: 1rem;
        margin-top: 1rem;
    }
</style>