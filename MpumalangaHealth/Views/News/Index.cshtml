@model List<NewsItem>
@{
    ViewData["Title"] = "News & Announcements";
}

<!-- News Page Header -->
<div class="news-page-header">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1>News & Announcements</h1>
                <p class="lead">Stay informed with the latest health updates from the Mpumalanga Department of Health</p>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <!-- Emergency Alert Banner -->
    @foreach (var newsItem in Model.Where(n => n.IsEmergency).Take(3))
    {
        <div class="emergency-alert alert-dismissible fade show" role="alert">
            <div class="d-flex align-items-start">
                <div class="flex-shrink-0">
                    <i class="fas fa-exclamation-triangle fa-3x me-4"></i>
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="alert-heading">🚨 EMERGENCY ALERT: @newsItem.Title</h5>
                        <small class="text-white opacity-75">@newsItem.PublishedDate.ToString("MMM dd, yyyy")</small>
                    </div>
                    <p class="mb-3">@newsItem.Summary</p>
                    <a href="@Url.Action("Details", new { id = newsItem.Id })" class="btn btn-warning">
                        Read Full Alert <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Category Filters -->
    <div class="category-filter-bar">
        <div class="row">
            <div class="col-12">
                <div class="d-flex flex-wrap gap-2 justify-content-center align-items-center">
                    <span class="text-primary fw-bold me-2">
                        <i class="fas fa-filter me-1"></i>Filter:
                    </span>
                    <a href="@Url.Action("Index")" class="filter-btn @(ViewBag.Category == null ? "btn-primary" : "btn-outline-primary")">
                        <i class="fas fa-newspaper me-1"></i>All News
                    </a>
                    <a href="@Url.Action("Emergency")" class="filter-btn btn-outline-danger">
                        <i class="fas fa-exclamation-triangle me-1"></i>Emergency
                    </a>
                    <a href="@Url.Action("Category", new { category = "Health Alert" })" class="filter-btn btn-outline-danger">
                        <i class="fas fa-shield-alt me-1"></i>Health Alerts
                    </a>
                    <a href="@Url.Action("Category", new { category = "Announcement" })" class="filter-btn btn-outline-primary">
                        <i class="fas fa-bullhorn me-1"></i>Announcements
                    </a>
                    <a href="@Url.Action("Category", new { category = "Vacancies" })" class="filter-btn btn-outline-success">
                        <i class="fas fa-briefcase me-1"></i>Vacancies
                    </a>
                    <a href="@Url.Action("Category", new { category = "Service Update" })" class="filter-btn btn-outline-info">
                        <i class="fas fa-sync-alt me-1"></i>Service Updates
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- News Grid -->
    <div class="row g-4">
        @foreach (var newsItem in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="news-card">
                    <!-- News Image -->
                    @if (!string.IsNullOrEmpty(newsItem.ImageUrl))
                    {
                        <img src="@newsItem.ImageUrl" class="news-card-img" alt="@newsItem.Title">
                    }
                    else
                    {
                        <img src="/images/news-placeholder.jpg" class="news-card-img" alt="News placeholder">
                    }

                    <!-- News Content -->
                    <div class="card-body">
                        <div class="news-meta">
                            <span class="badge @GetCategoryBadgeClass(newsItem.Category)">
                                @if (newsItem.Category == "Health Alert")
                                {
                                    <i class="fas fa-shield-alt me-1"></i>
                                }
                                else if (newsItem.Category == "Announcement")
                                {
                                    <i class="fas fa-bullhorn me-1"></i>
                                }
                                else if (newsItem.Category == "Vacancies")
                                {
                                    <i class="fas fa-briefcase me-1"></i>
                                }
                                else if (newsItem.Category == "Service Update")
                                {
                                    <i class="fas fa-sync-alt me-1"></i>
                                }
                                @newsItem.Category
                            </span>
                            <span class="news-date">
                                <i class="far fa-calendar-alt"></i>
                                @newsItem.PublishedDate.ToString("MMM dd, yyyy")
                            </span>
                        </div>

                        <h5 class="card-title">@newsItem.Title</h5>
                        <p class="card-text">@newsItem.Summary</p>

                        <div class="d-flex justify-content-between align-items-center mt-auto pt-3">
                            <a href="@Url.Action("Details", new { id = newsItem.Id })" class="btn btn-primary">
                                Read Full Article <i class="fas fa-arrow-right ms-2"></i>
                            </a>
                            @if (newsItem.IsEmergency)
                            {
                                <small class="text-danger">
                                    <i class="fas fa-exclamation-circle"></i> Important
                                </small>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- No News Message -->
    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-newspaper"></i>
            <h4>No news articles at the moment</h4>
            <p class="mb-0">Please check back later for updates</p>
        </div>
    }
</div>

@functions {
    public string GetCategoryBadgeClass(string category)
    {
        return category switch
        {
            "Health Alert" => "bg-danger",
            "Announcement" => "bg-primary",
            "Vacancies" => "bg-success",
            "Service Update" => "bg-info",
            _ => "bg-secondary"
        };
    }
}