@model NewsItem
@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Back Button -->
            <div class="mb-4">
                <a href="@Url.Action("Index")" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left me-2"></i>Back to News
                </a>
            </div>

            <!-- News Article -->
            <article class="news-article">
                <!-- Article Header -->
                <header class="mb-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <span class="badge @GetCategoryBadgeClass(Model.Category)">
                            @Model.Category
                        </span>
                        <small class="text-muted">Published: @Model.PublishedDate.ToString("MMMM dd, yyyy")</small>
                    </div>

                    <h1 class="display-6 fw-bold text-primary mb-3">@Model.Title</h1>

                    @if (Model.IsEmergency)
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <strong>Emergency Alert:</strong> This is an important health announcement
                        </div>
                    }
                </header>

                <!-- Article Image -->
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-4">
                        <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded">
                    </div>
                }

                <!-- Article Content -->
                <div class="article-content">
                    <p class="lead text-muted mb-4">@Model.Summary</p>

                    <div class="content-body">
                        <p style="white-space: pre-line;">@Model.Content</p>

                        <!-- Footer note -->
                        <div class="mt-4 p-3 bg-light rounded">
                            <p class="mb-0">
                                <i class="fas fa-info-circle text-primary me-2"></i>
                                For more information, please contact the Mpumalanga Department of Health call center at 0800 123 456.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Article Footer -->
                <footer class="mt-5 pt-4 border-top">
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-muted">Share this article:</h6>
                            <div class="d-flex gap-2">
                                <a href="https://www.facebook.com/sharer/sharer.php?u=@Context.Request.Host@Context.Request.Path"
                                   target="_blank" class="btn btn-outline-primary btn-sm">
                                    <i class="fab fa-facebook-f"></i>
                                </a>
                                <a href="https://twitter.com/intent/tweet?text=@Model.Title&url=@Context.Request.Host@Context.Request.Path"
                                   target="_blank" class="btn btn-outline-info btn-sm">
                                    <i class="fab fa-twitter"></i>
                                </a>
                                <a href="https://api.whatsapp.com/send?text=@Model.Title @Context.Request.Host@Context.Request.Path"
                                   target="_blank" class="btn btn-outline-success btn-sm">
                                    <i class="fab fa-whatsapp"></i>
                                </a>
                            </div>
                        </div>
                        <div class="col-md-6 text-md-end">
                            <small class="text-muted">
                                Last updated: @Model.PublishedDate.ToString("MMM dd, yyyy 'at' h:mm tt")
                            </small>
                        </div>
                    </div>
                </footer>
            </article>
        </div>
    </div>
</div>

@functions {
    public string GetCategoryBadgeClass(string category)
    {
        return category switch
        {
            "Health Alert" => "bg-danger",
            "Announcement" => "bg-primary",
            "Vacancies" => "bg-success",
            "Service Update" => "bg-info",
            _ => "bg-secondary"
        };
    }
}