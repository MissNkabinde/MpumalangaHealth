@{
    ViewData["Title"] = "Mpumalanga Department of Health";
}

<!-- MEC & Healthcare Facilities Section -->
<section class="mec-video-section">
    <div class="container">
        <div class="row align-items-center g-4">
            <!-- Left Side: Video -->
            <!-- Left Side: Video -->
            <div class="col-lg-7">
                <div class="video-container-sm">
                    <div class="video-wrapper-sm">
                        <video autoplay muted loop playsinline class="hero-video-sm">
                            <source src="~/images/Hospitals.mp4" type="video/mp4">
                            <source src="~/images/Hospitals.webm" type="video/webm">
                            Your browser does not support the video tag.
                        </video>
                        <div class="video-overlay-sm">
                            <div class="video-content">
                                <h2 class="video-title text-white mb-3">Transforming Healthcare in Mpumalanga</h2>
                                <p class="video-subtitle text-white mb-4">
                                    Committed to providing accessible, comprehensive healthcare services to all communities across the province.
                                </p>
                            </div>
                        </div>
                        <div class="video-description-card">
                            <p class="description-text">
                                The Mpumalanga Department of Health is responsible for providing public healthcare services in Mpumalanga. It manages hospitals and clinics, implements health programmes, and works to ensure accessible, quality healthcare for all residents of the province.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- IMPORTANT LINKS SECTION - ADD THIS RIGHT AFTER THE VIDEO -->
                <div class="important-links-container mt-4">
                    <div class="card">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fas fa-link me-2"></i>Important Links & Resources</h5>
                        </div>
                        <div class="card-body">
                            <div class="list-group list-group-flush">
                                <a href="https://www.dpsa.gov.za" target="_blank" class="list-group-item list-group-item-action d-flex align-items-center">
                                    <i class="fas fa-external-link-alt me-3 text-primary"></i>
                                    <div>
                                        <strong>DPSA</strong>
                                        <small class="d-block text-muted">Department of Public Service and Administration</small>
                                    </div>
                                </a>
                                <a href="https://erecruitment.mpg.gov.za/Default.aspx" target="_blank" class="list-group-item list-group-item-action d-flex align-items-center">
                                    <i class="fas fa-external-link-alt me-3 text-primary"></i>
                                    <div>
                                        <strong>MPUMALANGA E-RECRUITMENT</strong>
                                        <small class="d-block text-muted">Online recruitment portal for Mpumalanga</small>
                                    </div>
                                </a>
                                <a href="https://ehr.mpuhealth.gov.za/OnlineApp/Advert.aspx" target="_blank" class="list-group-item list-group-item-action d-flex align-items-center">
                                    <i class="fas fa-external-link-alt me-3 text-primary"></i>
                                    <div>
                                        <strong>MPUMALANGA DOH APPLICATION SYSTEM</strong>
                                        <small class="d-block text-muted">Department of Health application portal</small>
                                    </div>
                                </a>
                                <a href="https://www.hpcsa.co.za/" target="_blank" class="list-group-item list-group-item-action d-flex align-items-center">
                                    <i class="fas fa-external-link-alt me-3 text-primary"></i>
                                    <div>
                                        <strong>Health Professions Council of SA (HPCSA)</strong>
                                        <small class="d-block text-muted">Professional body for health practitioners</small>
                                    </div>
                                </a>
                                <a href="https://www.sanc.co.za/" target="_blank" class="list-group-item list-group-item-action d-flex align-items-center">
                                    <i class="fas fa-external-link-alt me-3 text-primary"></i>
                                    <div>
                                        <strong>South African Nursing Council (SANC)</strong>
                                        <small class="d-block text-muted">Nursing profession regulation</small>
                                    </div>
                                </a>
                                <a href="https://www.health.gov.za/" target="_blank" class="list-group-item list-group-item-action d-flex align-items-center">
                                    <i class="fas fa-external-link-alt me-3 text-primary"></i>
                                    <div>
                                        <strong>National Department of Health</strong>
                                        <small class="d-block text-muted">National health portal and resources</small>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <!-- Right Side: MEC Profile -->
            <div class="col-lg-5">
                <div class="mec-profile-card">
                    <div class="mec-image-wrapper">
                        <img src="~/images/MEC.png" alt="Honorable Sasekani J. Manzini - MEC for Health" class="mec-image-profile">
                    </div>
                    <div class="mec-bio-content p-4">
                        <h3 class="mec-name text-primary mb-2">Sasekani J. Manzini</h3>
                        <h5 class="mec-position text-muted mb-3">Member of Executive Council for Health</h5>
                        <div class="mec-description">
                            <p class="text-muted mb-3">
                                Honorable Sasekani J. Manzini is dedicated to transforming healthcare delivery
                                across Mpumalanga Province. With a strong commitment to accessible, quality
                                healthcare for all, she leads initiatives to improve hospital infrastructure,
                                enhance primary healthcare services, and address healthcare disparities in
                                rural communities.
                            </p>
                            <p class="text-muted mb-0">
                                Under her leadership, the department continues to innovate and implement
                                strategies that prioritize patient care and community wellbeing.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section class="bg-light-custom">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="text-primary mb-3">Our Services</h2>
            <p class="lead text-muted">Comprehensive healthcare services across the province</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card service-card h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-wrapper bg-primary rounded-circle mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="fas fa-user-md fa-2x text-white"></i>
                        </div>
                        <h5 class="card-title text-primary">Primary Healthcare</h5>
                        <p class="card-text text-muted">Essential health services at clinics throughout the province.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card service-card h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-wrapper bg-primary rounded-circle mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="fas fa-hospital fa-2x text-white"></i>
                        </div>
                        <h5 class="card-title text-primary">Hospital Care</h5>
                        <p class="card-text text-muted">Specialized medical treatment and emergency services.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card service-card h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-wrapper bg-primary rounded-circle mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="fas fa-baby fa-2x text-white"></i>
                        </div>
                        <h5 class="card-title text-primary">Maternal Health</h5>
                        <p class="card-text text-muted">Comprehensive care for mothers and children.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Districts Section -->
<section>
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="text-primary mb-3">Our Districts</h2>
            <p class="lead text-muted">Healthcare services across Mpumalanga</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card district-card h-100 text-center">
                    <div class="card-body p-4">
                        <div class="icon-wrapper bg-primary rounded-circle mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                            <i class="fas fa-map-marker-alt fa-2x text-white"></i>
                        </div>
                        <h5 class="text-primary">Ehlanzeni</h5>
                        <p class="text-muted">Serving communities in and around Mbombela</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card district-card h-100 text-center">
                    <div class="card-body p-4">
                        <div class="icon-wrapper bg-primary rounded-circle mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                            <i class="fas fa-map-marker-alt fa-2x text-white"></i>
                        </div>
                        <h5 class="text-primary">Gert Sibande</h5>
                        <p class="text-muted">Healthcare services for Gert Sibande region</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card district-card h-100 text-center">
                    <div class="card-body p-4">
                        <div class="icon-wrapper bg-primary rounded-circle mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                            <i class="fas fa-map-marker-alt fa-2x text-white"></i>
                        </div>
                        <h5 class="text-primary">Nkangala</h5>
                        <p class="text-muted">Medical care for Nkangala district communities</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>