@{
    ViewData["Title"] = "Contact Us";
    var lastUpdated = ViewData["LastUpdated"] as string ?? DateTime.Now.ToString("dd MMMM yyyy");
}

<div class="container py-5">
    <div class="row">
        <div class="col-12">
            <h1 class="display-5 fw-bold text-primary mb-3">Contact Us</h1>
            <p class="text-muted mb-4">Last updated: @lastUpdated</p>

            <!-- Add your contact form/content here -->
            <div class="row">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title text-primary">Head Office</h5>
                            <p class="card-text">
                                Provincial Offices<br>
                                Government Boulevard<br>
                                Mbombela<br>
                                1200
                            </p>
                            <p class="card-text">
                                <strong>Phone:</strong> 013 766 3000<br>
                                <strong>Email:</strong> info@mpuhealth.gov.za
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>