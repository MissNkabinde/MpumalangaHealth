
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mpumalanga Department of Health</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <!-- Top Header Strip (Green) -->
    <div class="top-header bg-primary py-2">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <small class="text-white">
                        <i class="fas fa-phone-alt me-1"></i> Contact Centre: 013 766 3429
                    </small>
                </div>
                <div class="col-md-6 text-md-end">
                    <small class="text-white">
                        <i class="fas fa-envelope me-1"></i> info@mpuhealth.gov.za
                    </small>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Header with Logo and Sunrise -->
    <header class="main-header bg-white">
        <div class="container">
            <div class="row align-items-center py-3">
                <!-- Logo and Text Section - Now with more space for logo -->
                <div class="col-md-8">
                    <!-- Increased from col-md-6 to col-md-8 -->
                    <div class="main-logo">
                        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                            <div class="d-flex align-items-center">
                                <div class="logo-container">
                                    <img src="~/images/logo.png" alt="Mpumalanga Department of Health Logo" class="logo-img">
                                </div>
                                <!-- Text moved to the right with margin-left -->
                                <div class="text-start ms-5">
                                    <!-- ms-5 = margin-left large -->
                                    <div class="h5 text-dark fw-bold mb-0">MPUMALANGA DEPARTMENT OF HEALTH</div>
                                    <div class="small text-muted mt-1">www.mpuhealth.gov.za</div>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>

                <!-- Sunrise Image - Right Side (smaller column) -->
                <div class="col-md-4 text-md-end">
                    <!-- Decreased from col-md-6 to col-md-4 -->
                    <div class="sunrise-container">
                        <img src="~/images/sunrise.png" alt="Mpumalanga Sunrise" class="sunrise-img">
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Sticky Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container">
            <!-- Mobile Toggle -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Navigation Menu -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link text-dark fw-bold" asp-controller="Home" asp-action="Index">HOME</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link text-dark fw-bold dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            ABOUT US
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="About" asp-action="Index">About Department</a></li>
                            <li><a class="dropdown-item" asp-controller="About" asp-action="VisionMission">Vision & Mission</a></li>
                            <li><a class="dropdown-item" asp-controller="About" asp-action="Management">Management Team</a></li>
                            <li><a class="dropdown-item" asp-controller="About" asp-action="Districts">Our Districts</a></li>
                            <li><a class="dropdown-item" asp-controller="About" asp-action="Structure">Organizational Structure</a></li>
                            <li><hr class="dropdown-divider"></li>

                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link text-dark fw-bold dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            SERVICES
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Services" asp-action="Index">All Services</a></li>
                            <li><a class="dropdown-item" asp-controller="Services" asp-action="Category" asp-route-category="Primary Health Care">Primary Health Care</a></li>
                            <li><a class="dropdown-item" asp-controller="Services" asp-action="Category" asp-route-category="Hospital Services">Hospital Services</a></li>
                            <li><a class="dropdown-item" asp-controller="Services" asp-action="Category" asp-route-category="Emergency Services">Emergency Services</a></li>
                            <li><a class="dropdown-item" asp-controller="Services" asp-action="Category" asp-route-category="Maternal & Child Health">Maternal & Child Health</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" asp-controller="Services" asp-action="Programs">Health Programs</a></li>
                            <li><a class="dropdown-item" asp-controller="Services" asp-action="Emergency">Emergency Info</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link text-dark fw-bold dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            FACILITIES
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Facilities" asp-action="Index">Find Facilities</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="#">Provincial Office</a></li>
                            <li><a class="dropdown-item" href="#">Ehlanzeni District</a></li>
                            <li><a class="dropdown-item" href="#">Gert Sibande District</a></li>
                            <li><a class="dropdown-item" href="#">Nkangala District</a></li>
                        </ul>
                    </li>
                    <!-- In your main site's navigation -->
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark fw-bold" asp-controller="News" asp-action="Index">NEWS</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link text-dark fw-bold dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            VACANCIES
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Careers" asp-action="Index">View All Vacancies</a></li>
                            <li><a class="dropdown-item" href="#">Internship Programs</a></li>
                            <li><a class="dropdown-item" href="#">Nursing Intake</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="#">Application Guidelines</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark fw-bold" asp-controller="Tenders" asp-action="Index">TENDERS</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark fw-bold" asp-controller="Contact" asp-action="Index">CONTACT</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    </header>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white pt-5 pb-3">
        <div class="container">
            <div class="row">
                <!-- Contact Information -->
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5 class="text-warning">CONTACT US</h5>
                    <p class="mb-2">
                        <i class="fas fa-map-marker-alt text-warning me-2"></i>
                        Provincial Offices, Indwe Building, Government Boulevard, Mbombela
                    </p>
                    <p class="mb-2">
                        <i class="fas fa-phone text-warning me-2"></i>
                        013 766 3000
                    </p>
                    <p class="mb-0">
                        <i class="fas fa-envelope text-warning me-2"></i>
                        info@mpuhealth.gov.za
                    </p>
                </div>

                <!-- Quick Links -->
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5 class="text-warning">QUICK LINKS</h5>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a href="#" class="text-white text-decoration-none">Hospitals & Clinics</a></li>
                        <li class="mb-1"><a href="#" class="text-white text-decoration-none">Career Opportunities</a></li>
                        <li class="mb-1"><a href="#" class="text-white text-decoration-none">Tenders</a></li>
                        <li class="mb-1"><a href="#" class="text-white text-decoration-none">News & Updates</a></li>
                        <li class="mb-0"><a href="#" class="text-white text-decoration-none">Health Programs</a></li>
                    </ul>
                </div>

                <!-- Emergency -->
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5 class="text-warning">EMERGENCY</h5>
                    <div class="bg-danger text-white p-3 rounded">
                        <h6 class="mb-2"><i class="fas fa-ambulance me-2"></i>EMERGENCY SERVICES</h6>
                        <p class="mb-1">Ambulance: 10177</p>
                        <p class="mb-0">Cellphone Emergency: 112</p>
                    </div>
                </div>
            </div>

            <hr class="bg-warning my-4">

            <!-- Legal Links -->
            <div class="row mb-3">
                <div class="col-12 text-center">
                    <div class="legal-links">
                        <a asp-controller="Legal" asp-action="Accessibility" class="text-white text-decoration-none me-3">Accessibility</a>
                        <a asp-controller="Legal" asp-action="Disclaimer" class="text-white text-decoration-none me-3">Disclaimer</a>
                        <a asp-controller="Legal" asp-action="Privacy" class="text-white text-decoration-none me-3">Privacy Policy</a>
                        <a asp-controller="Legal" asp-action="Terms" class="text-white text-decoration-none">Terms of Use</a>
                    </div>
                </div>
            </div>

            <!-- Copyright -->
            <div class="row align-items-center">
                <div class="col-md-6">
                    <p class="mb-0">&copy; @DateTime.Now.Year Mpumalanga Provincial Government. All rights reserved.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-0 text-muted">
                        <small>Last updated: @DateTime.Now.ToString("dd MMMM yyyy 'at' HH:mm")</small>
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>