@{
    ViewData["Title"] = "Admin Login";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Admin Login</title>
    <style>
        body {
            font-family: Arial;
            background: #f0f0f0;
            padding: 50px;
        }

        .login-box {
            background: white;
            padding: 30px;
            max-width: 400px;
            margin: 0 auto;
            border-radius: 10px;
        }

        input {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
        }

        button {
            background: blue;
            color: white;
            padding: 10px;
            width: 100%;
            border: none;
        }
    </style>
</head>
<body>
    <div class="login-box">
        <h2>Admin Login</h2>
        @if (ViewBag.Error != null)
        {
            <div style="color: red; margin: 10px 0;">@ViewBag.Error</div>
        }
        <form method="post">
            <input type="text" name="username" placeholder="Username" value="admin" required>
            <input type="password" name="password" placeholder="Password" value="pass1" required>
            <button type="submit">LOGIN</button>
        </form>
        <p><small>Use: admin / pass1</small></p>
    </div>
</body>
</html>