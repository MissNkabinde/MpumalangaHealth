@model List<ManagementTeam>
@{
    ViewData["Title"] = "Management Team";
}

<div class="container py-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "About")">About Us</a></li>
            <li class="breadcrumb-item active" aria-current="page">Management Team</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-5 fw-bold text-primary mb-3">Management Team</h1>
            <p class="lead text-muted">Meet the leadership driving healthcare excellence in Mpumalanga</p>
        </div>
    </div>

    <!-- Management Team Grid -->
    <div class="row">
        @foreach (var member in Model)
        {
            <div class="col-lg-6 mb-4">
                <div class="card management-card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 text-center">
                                <!-- Profile Photo Placeholder -->
                                <div class="profile-placeholder bg-primary rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center"
                                     style="width: 120px; height: 120px;">
                                    <i class="fas fa-user fa-3x text-white"></i>
                                </div>
                                <h5 class="text-primary mb-1">@member.Name</h5>
                                <small class="text-muted">@member.Position</small>
                            </div>
                            <div class="col-md-8">
                                <div class="management-info">
                                    <h6 class="text-primary mb-2">
                                        <i class="fas fa-building me-2"></i>@member.Department
                                    </h6>

                                    <div class="qualifications mb-3">
                                        <small class="text-muted">
                                            <i class="fas fa-graduation-cap me-1"></i>
                                            @member.Qualifications
                                        </small>
                                    </div>

                                    <p class="small text-muted mb-3">@member.Biography</p>

                                    <div class="contact-info">
                                        <div class="d-flex flex-wrap gap-3">
                                            <small>
                                                <i class="fas fa-envelope text-primary me-1"></i>
                                                <a href="mailto:@member.Email" class="text-muted">@member.Email</a>
                                            </small>
                                            <small>
                                                <i class="fas fa-phone text-primary me-1"></i>
                                                <span class="text-muted">@member.Phone</span>
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Executive Support -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="card bg-light">
                <div class="card-body p-4">
                    <h4 class="text-primary mb-3">
                        <i class="fas fa-hands-helping me-2"></i>Executive Support Team
                    </h4>
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Senior Management</h6>
                            <ul class="small text-muted">
                                <li>Directors of various programs and units</li>
                                <li>District Health Managers</li>
                                <li>Hospital Chief Executive Officers</li>
                                <li>Program Managers</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h6>Support Services</h6>
                            <ul class="small text-muted">
                                <li>Human Resources Management</li>
                                <li>Finance and Supply Chain</li>
                                <li>Information Technology</li>
                                <li>Communication and Marketing</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .management-card {
        transition: all 0.3s ease;
        border: none;
    }

        .management-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1) !important;
        }

    .profile-placeholder {
        border: 3px solid var(--mustard);
    }

    .management-info h6 {
        font-weight: 600;
    }

    .qualifications {
        background-color: #f8f9fa;
        padding: 0.5rem;
        border-radius: 4px;
        border-left: 3px solid var(--primary-blue);
    }
</style>