@model OrganizationalStructure
@{
    ViewData["Title"] = "Vision & Mission";
}

<div class="container py-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "About")">About Us</a></li>
            <li class="breadcrumb-item active" aria-current="page">Vision & Mission</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-5 fw-bold text-primary mb-3">Vision & Mission</h1>
            <p class="lead text-muted">Guiding our commitment to healthcare excellence</p>
        </div>
    </div>

    <!-- Vision Card -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="card border-warning shadow-sm">
                <div class="card-header bg-warning text-dark py-3">
                    <h3 class="card-title mb-0">
                        <i class="fas fa-bullseye me-2"></i>Our Vision
                    </h3>
                </div>
                <div class="card-body p-4">
                    <blockquote class="blockquote mb-0">
                        <p class="display-6 text-center text-primary fst-italic">"@Model.Vision"</p>
                    </blockquote>
                </div>
            </div>
        </div>
    </div>

    <!-- Mission Card -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="card border-primary shadow-sm">
                <div class="card-header bg-primary text-white py-3">
                    <h3 class="card-title mb-0">
                        <i class="fas fa-flag me-2"></i>Our Mission
                    </h3>
                </div>
                <div class="card-body p-4">
                    <p class="lead text-center text-muted">@Model.Mission</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Values -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-light py-3">
                    <h3 class="card-title mb-0 text-primary">
                        <i class="fas fa-heart me-2"></i>Our Values
                    </h3>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        @foreach (var value in Model.Values.Split('\n'))
                        {
                            <div class="col-md-6 mb-3">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-check-circle text-primary me-3"></i>
                                    <span class="h5 mb-0 text-muted">@value</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Additional Information -->
    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-light">
                    <h4 class="text-primary mb-0">
                        <i class="fas fa-history me-2"></i>Our History
                    </h4>
                </div>
                <div class="card-body">
                    <p class="text-muted">@Model.History</p>
                </div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-light">
                    <h4 class="text-primary mb-0">
                        <i class="fas fa-gavel me-2"></i>Our Mandate
                    </h4>
                </div>
                <div class="card-body">
                    <p class="text-muted">@Model.Mandate</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Call to Action -->
    <div class="row mt-5">
        <div class="col-12 text-center">
            <div class="card bg-primary text-white">
                <div class="card-body py-5">
                    <h3 class="mb-3">Join Us in Our Mission</h3>
                    <p class="lead mb-4">Together, we can build a healthier Mpumalanga for all</p>
                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                        <a href="@Url.Action("Management")" class="btn btn-warning btn-lg">
                            <i class="fas fa-users me-2"></i>Meet Our Team
                        </a>
                        <a href="@Url.Action("Districts")" class="btn btn-light btn-lg">
                            <i class="fas fa-map me-2"></i>Explore Districts
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>