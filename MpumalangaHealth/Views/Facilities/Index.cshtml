@model List<MpumalangaHealth.Controllers.Facility>
@{
    ViewData["Title"] = "Hospitals - Mpumalanga Department of Health";
    var currentSearch = ViewBag.CurrentSearch as string ?? "";
    var currentDistrict = ViewBag.CurrentDistrict as string ?? "";
}

<div class="container py-5">
    <!-- Page Header -->
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-5 fw-bold text-primary mb-3">Hospitals in Mpumalanga</h1>
            <p class="lead text-muted">Find hospitals and their contact information across the province</p>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="stats-card">
                <div class="stats-number">@ViewBag.TotalHospitals</div>
                <div class="stats-label">Hospitals</div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="stats-card">
                <div class="stats-number">3</div>
                <div class="stats-label">Districts</div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="stats-card">
                <div class="stats-number">24/7</div>
                <div class="stats-label">Emergency Services</div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="filter-section mb-4">
        <form method="get" action="@Url.Action("Index")" id="filterForm">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="search-box">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" name="search" class="search-input"
                               placeholder="Search by hospital name or address..."
                               value="@currentSearch">
                    </div>
                </div>
                <div class="col-md-4">
                    <select name="district" class="filter-select" onchange="this.form.submit()">
                        <option value="">All Districts</option>
                        <option value="Ehlanzeni" selected="@(currentDistrict == "Ehlanzeni")">Ehlanzeni</option>
                        <option value="Gert Sibande" selected="@(currentDistrict == "Gert Sibande")">Gert Sibande</option>
                        <option value="Nkangala" selected="@(currentDistrict == "Nkangala")">Nkangala</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary w-100">Clear</a>
                </div>
            </div>
        </form>
    </div>

    <!-- Quick Filter Chips -->
    <div class="filter-chips mb-4">
        <span class="filter-label">Quick filters:</span>
        <a href="@Url.Action("Index", new { district = "Ehlanzeni", search = currentSearch })"
           class="filter-chip @(currentDistrict == "Ehlanzeni" ? "active" : "")">
            <i class="fas fa-map-pin"></i> Ehlanzeni
        </a>
        <a href="@Url.Action("Index", new { district = "Gert Sibande", search = currentSearch })"
           class="filter-chip @(currentDistrict == "Gert Sibande" ? "active" : "")">
            <i class="fas fa-map-pin"></i> Gert Sibande
        </a>
        <a href="@Url.Action("Index", new { district = "Nkangala", search = currentSearch })"
           class="filter-chip @(currentDistrict == "Nkangala" ? "active" : "")">
            <i class="fas fa-map-pin"></i> Nkangala
        </a>
    </div>

    <!-- Hospitals Grid -->
    @if (Model.Any())
    {
        <div class="row">
            @foreach (var hospital in Model)
            {
                <div class="col-lg-6 mb-4">
                    <div class="hospital-card">
                        <div class="hospital-card-header">
                            <div class="hospital-type-badge bg-primary">
                                <i class="fas fa-building me-1"></i> Hospital
                            </div>
                            <div class="hospital-district">
                                <i class="fas fa-map-marker-alt"></i> @hospital.District
                            </div>
                        </div>

                        <h3 class="hospital-card-title">
                            <a asp-action="Details" asp-route-id="@hospital.Id">@hospital.Name</a>
                        </h3>

                        <div class="hospital-info">
                            <div class="info-row">
                                <i class="fas fa-phone-alt"></i>
                                <span><strong>Phone:</strong> @hospital.Phone</span>
                            </div>
                            <div class="info-row">
                                <i class="fas fa-map-pin"></i>
                                <span><strong>Address:</strong> @hospital.Address</span>
                            </div>
                            <div class="info-row">
                                <i class="fas fa-clock"></i>
                                <span><strong>Hours:</strong> @hospital.OperatingHours</span>
                            </div>
                        </div>

                        @if (hospital.Specialties.Any())
                        {
                            <div class="hospital-specialties">
                                <strong><i class="fas fa-stethoscope"></i> Specialties:</strong>
                                @foreach (var specialty in hospital.Specialties.Take(3))
                                {
                                    <span class="specialty-tag">@specialty</span>
                                }
                                @if (hospital.Specialties.Count > 3)
                                {
                                    <span class="specialty-tag">+@(hospital.Specialties.Count - 3) more</span>
                                }
                            </div>
                        }

                        <div class="hospital-card-actions">
                            <a asp-action="Details" asp-route-id="@hospital.Id" class="btn btn-primary">
                                <i class="fas fa-info-circle me-1"></i> View Details
                            </a>
                            @if (hospital.Latitude.HasValue && hospital.Longitude.HasValue)
                            {
                                <a href="https://maps.google.com/?q=@hospital.Latitude,@hospital.Longitude"
                                   target="_blank" class="btn btn-outline-secondary">
                                    <i class="fas fa-directions me-1"></i> Directions
                                </a>
                            }
                            <button class="btn btn-outline-primary" onclick="copyPhoneNumber('@hospital.Phone')">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fas fa-hospital-user fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">No hospitals found</h4>
            <p class="text-muted">Try adjusting your search criteria</p>
            <a href="@Url.Action("Index")" class="btn btn-primary">Clear All Filters</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function copyPhoneNumber(phone) {
            navigator.clipboard.writeText(phone).then(function() {
                var notification = document.createElement('div');
                notification.className = 'toast-notification';
                notification.innerHTML = '<i class="fas fa-check-circle"></i> Phone number copied!';
                document.body.appendChild(notification);

                setTimeout(function() {
                    notification.remove();
                }, 2000);
            });
        }

        document.querySelectorAll('.filter-select').forEach(select => {
            select.addEventListener('change', function() {
                document.getElementById('filterForm').submit();
            });
        });
    </script>
}